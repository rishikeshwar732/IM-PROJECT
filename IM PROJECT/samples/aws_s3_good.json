{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TeamReadAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": [
          "arn:aws:iam::123456789012:role/guardrail-ai-dev-team"
        ]
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::guardrail-ai-demo-good",
        "arn:aws:s3:::guardrail-ai-demo-good/*"
      ]
    }
  ]
}

